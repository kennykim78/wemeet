{
  "name": "aa-archigroup-static",
  "version": "1.0.0",
  "description": "Static site for AA archigroup",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-static-js.mjs",
    "build:css": "sass scss:css --style expanded",
    "watch:css": "sass --watch scss:css --style expanded",
    "check:scss-source": "node scripts/enforce-scss-source.mjs",
    "setup:hooks": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "sass": "^1.70.0",
    "vite": "^8.0.14",
    "vite-plugin-html-inject": "^1.1.2"
  }
}
